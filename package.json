{
  "name": "react-calendar-picker",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight React + TypeScript calendar and date picker with Gregorian and Jalali support, optional time selection, and CSS-variable theming.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "react",
    "typescript",
    "calendar",
    "date-picker",
    "datepicker",
    "jalali",
    "persian",
    "gregorian",
    "shamsi",
    "css-variables"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/react-calendar-picker.git"
  },
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles/styles.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1"
  }
}
